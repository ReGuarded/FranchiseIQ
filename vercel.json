{
  "version": 2,
  "builds": [
    {
      "src": "api/chat.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/chat",
      "dest": "/api/chat.js"
    },
    {
      "src": "/report",
      "dest": "/public/report.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}

