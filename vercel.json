{
  "version": 2,
  "outputDirectory": "public",
  "builds": [
    {
      "src": "api/chat.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/chat",
      "dest": "/api/chat.js"
    },
    {
      "src": "/report",
      "dest": "/report.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
