{
  "version": 2,
  "functions": {
    "api/chat.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/chat",
      "dest": "/api/chat.js"
    },
    {
      "src": "/report",
      "dest": "/public/report.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
